# ─────────────────────────────────────────────────────────────────────────────
# KAIZEN STAGING — Variables de entorno
# Copia este archivo a .env.staging y rellena los valores reales del Synology.
# ¡NO subas este archivo a git con credenciales reales!
# ─────────────────────────────────────────────────────────────────────────────

# URL completa de la DB de producción (PostgreSQL en el Synology/NAS)
# Formato: postgresql://usuario:password@IP_SYNOLOGY:5432/nombre_db
PROD_DATABASE_URL=postgresql://kaizoku:kaizoku@192.168.1.XXX:5432/kaizoku

# Redis de producción (en el Synology/NAS)
PROD_REDIS_HOST=192.168.1.XXX
PROD_REDIS_PORT=6379

# Puerto de staging (diferente al de prod que suele ser 3000)
STAGING_PORT=3001
