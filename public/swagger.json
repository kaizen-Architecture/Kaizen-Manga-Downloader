{
  "openapi": "3.0.0",
  "info": {
    "title": "Kaizen API",
    "description": "REST API for integrating with the Kaizen manga downloader.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/mangas": {
      "get": {
        "summary": "Get all mangas",
        "description": "Retrieve a list of all mangas in the Kaizen library.",
        "responses": {
          "200": {
            "description": "A list of mangas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "integer" },
                      "title": { "type": "string" },
                      "source": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden (API disabled)" }
        }
      }
    },
    "/mangas/{id}": {
      "get": {
        "summary": "Get manga details",
        "description": "Retrieve details of a specific manga by its ID.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Manga details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "integer" },
                    "title": { "type": "string" },
                    "source": { "type": "string" },
                    "chapters": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer" },
                          "index": { "type": "integer" },
                          "fileName": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid ID format" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden (API disabled)" },
          "404": { "description": "Manga not found" }
        }
      }
    }
  }
}
