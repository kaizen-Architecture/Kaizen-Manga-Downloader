#!/usr/bin/with-contenv bash

echo "[Kaizen] Starting configuration..."

cd /app

# Run migrations with robust retry to handle database startup delays
echo "[Kaizen] Running database migrations..."
for i in {1..10}; do
  echo "[Kaizen] Attempting to deploy database migrations (attempt $i/10)..."
  if ./node_modules/.bin/prisma migrate deploy; then
    echo "[Kaizen] Database migrations deployed successfully!"
    break
  fi
  echo "[Kaizen] Database not ready or migrate failed, sleeping 3 seconds..."
  sleep 3
done

# Setup mangal data
echo "[Kaizen] Syncing mangal configuration..."
mkdir -p /config/.config
cp -r /mangal /config/.config/ 2>/dev/null || true

# Cleanup cache
rm -f /config/.cache/mangal/Mangasee_custom_mangas.json

# Optimized permissions: only touch top-level if needed
# We avoid recursive chown on /app and /data because it's extremely slow
echo "[Kaizen] Ensuring directory existence..."
mkdir -p /config /logs /data

# Only chown the directories themselves, not contents (unless needed)
chown abc:abc /config /logs /data

echo "[Kaizen] Configuration complete. Starting app..."